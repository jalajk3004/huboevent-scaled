{
  "name": "hubo-events-api",
  "version": "1.0.0",
  "description": "HubO Events REST API — Express + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:cluster": "node dist/cluster.js",
    "start:pm2": "pm2 start ecosystem.config.cjs --env development",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop hubo-events-api",
    "pm2:reload": "pm2 reload hubo-events-api",
    "pm2:restart": "pm2 restart hubo-events-api",
    "pm2:delete": "pm2 delete hubo-events-api",
    "pm2:logs": "pm2 logs hubo-events-api",
    "pm2:status": "pm2 status",
    "deploy": "npm run build && npm run pm2:start"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "paytmchecksum": "^1.5.1",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/paytmchecksum": "^1.5.0",
    "pm2": "^6.0.14",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
